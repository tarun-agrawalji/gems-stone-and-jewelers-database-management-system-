// This is a Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(STAFF)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  auditLogs     AuditLog[]
}

enum Role {
  ADMIN
  STAFF
}

model Lot {
  id          String      @id @default(cuid())
  lotNo       String      @unique
  itemName    String?
  category    Category    @default(ROUGH)
  supplierName String?
  description  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  purchases   Purchase[]
  subLots     SubLot[]
  ledgerEntries StockLedger[]
}

enum Category {
  ROUGH
  READY_GOODS
  BY_ORDER
}

model SubLot {
  id              String    @id @default(cuid())
  subLotNo        String
  lotId           String
  parentSubLotId  String?
  parentSubLot    SubLot?   @relation("SubLotSplit", fields: [parentSubLotId], references: [id])
  childSubLots    SubLot[]  @relation("SubLotSplit")
  lot             Lot       @relation(fields: [lotId], references: [id])
  status          SubLotStatus @default(IN_STOCK)
  weight          Float
  weightUnit      WeightUnit @default(G)
  pieces          Int?
  shape           String?
  size            String?
  lines           Int?
  length          Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  manufacturing   Manufacturing[]
  sales           Sale[]
  ledgerEntries   StockLedger[]
  labels          Label[]
}

enum SubLotStatus {
  IN_STOCK
  IN_PROCESS
  READY
  PARTIALLY_SOLD
  CLOSED
  RETURNED
  PENDING
  CLOSED_RETURNED
}

enum WeightUnit {
  G
  KG
  CT
}

model Purchase {
  id              String    @id @default(cuid())
  lotId           String
  lot             Lot       @relation(fields: [lotId], references: [id])
  date            DateTime
  itemName        String?
  supplierName    String?
  descriptionRef  String?
  // RECEIVED
  grossWeight     Float
  lessWeight      Float     @default(0)
  netWeight       Float
  weightUnit      WeightUnit @default(G)
  size            String?
  shape           String?
  lines           Int?
  lineLength      Float?
  pieces          Int?
  
  // SELECTION
  selectionWeight Float?
  selectionPieces Int?
  selectionLines  Int?
  selectionLength Float?

  // REJECTION
  rejectionWeight Float?
  rejectionPieces Int?
  rejectionLines  Int?
  rejectionLength Float?
  rejectionDate   DateTime?
  rejectionStatus RejectionStatus?

  // PRICING
  purchasePrice   Float
  costPerGram     Float?
  totalCost       Float
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum RejectionStatus {
  PENDING
  RETURNED
  RESELLABLE
  CLOSED
}

model Manufacturing {
  id                    String    @id @default(cuid())
  subLotId              String
  subLot                SubLot    @relation(fields: [subLotId], references: [id])
  date                  DateTime
  entryType             String    @default("ISSUED") // "ISSUED" or "RECEIVED"
  issuedTo              String?
  weight                Float
  weightUnit            WeightUnit @default(G)
  pieces                Int?
  shape                 String?
  size                  String?
  lines                 Int?
  length                Float?
  labourCost            Float     @default(0)
  otherCost             Float     @default(0)
  totalManufacturingCost Float
  
  // SELECTION
  selectionWeight       Float?
  selectionPieces       Int?
  selectionShape        String?
  selectionSize         String?
  selectionLines        Int?
  selectionLength       Float?

  // REJECTION
  rejectionWeight       Float?
  rejectionPieces       Int?
  rejectionLines        Int?
  rejectionLength       Float?
  returnToManufacturer  Boolean?
  returnDate            DateTime?
  
  status                ManufacturingStatus @default(IN_PROCESS)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

enum ManufacturingStatus {
  IN_PROCESS
  COMPLETED
  REJECTED
  RETURNED_TO_MANUFACTURER
}

model Sale {
  id              String    @id @default(cuid())
  subLotId        String
  subLot          SubLot    @relation(fields: [subLotId], references: [id])
  date            DateTime
  itemName        String?
  descriptionRef  String?
  
  // ITEM DETAILS
  weight          Float?
  weightUnit      WeightUnit @default(G)
  size            String?
  shape           String?
  pieces          Int?
  lines           Int?
  length          Float?

  soldTo          String?
  salePrice       Float
  discount        Float     @default(0)
  netSale         Float
  tax             Float     @default(0)
  finalBillAmount Float
  billNo          String?
  
  // CUSTOMER RETURN (REJECTION)
  returnedWeight  Float?
  returnedPieces  Int?
  returnedLines   Int?
  returnedLength  Float?
  returnDate      DateTime?
  
  status          SaleStatus @default(SOLD)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum SaleStatus {
  SOLD
  PARTIALLY_RETURNED
  RETURNED
}

model StockLedger {
  id            String    @id @default(cuid())
  date          DateTime
  lotId         String?
  lot           Lot?      @relation(fields: [lotId], references: [id])
  subLotId      String?
  subLot        SubLot?   @relation(fields: [subLotId], references: [id])
  fromLocation  String
  toLocation    String
  weight        Float
  weightUnit    WeightUnit @default(G)
  pieces        Int?
  referenceType String
  referenceId   String
  notes         String?
  createdAt     DateTime  @default(now())
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  tableName   String
  recordId    String
  action      String
  oldData     String?
  newData     String?
  timestamp   DateTime  @default(now())
}

model Label {
  id          String    @id @default(cuid())
  subLotId    String
  subLot      SubLot    @relation(fields: [subLotId], references: [id])
  shopName    String?
  labelType   LabelType @default(STOCK)
  printedAt   DateTime  @default(now())
  selectionMark String?
}

enum LabelType {
  STOCK
  RECEIVED
}
